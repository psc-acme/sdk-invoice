{
    "name": "psc-acme/sdk-invoice",
    "description": "Package sdk-invoice for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\SdkInvoice\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/lock": "^7.0",
        "nette/utils": "^4.0",
        "psr/cache": "^3.0",
        "symfony/uid": "^7.0",
        "psc-acme/registry-billing": "^1.0",
        "psc-acme/monitor-billing": "^1.0"
    },
    "require-dev": {
        "symfony/phpunit-bridge": "^7.0",
        "phpunit/phpunit": "^10.5",
        "infection/infection": "^0.27"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}